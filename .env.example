# =============================================================
# Client-side env vars (used by React, prefixed VITE_)
# These are safe to expose — they end up in the browser bundle.
# Set in: .env.local (local dev) AND Netlify dashboard (deployed)
# =============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# =============================================================
# Server-side env vars (used by Netlify Functions ONLY)
# NEVER prefix with VITE_ — these must stay server-side.
# Set in: Netlify dashboard only (NOT in .env.local — pointless there)
# =============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxx           # bypasses RLS — server only
GHL_PIT_TOKEN=pit-xxxxxxxxxxxx                # GoHighLevel Private Integration Token
GHL_LOCATION_ID=xxxxxxxxxxx                   # GoHighLevel sub-account / Location ID

# Phase 4: 24-hour reminder cron auth. A long random string that the cron
# service must include as ?secret=... or X-Cron-Secret header.
CRON_SECRET=replace-with-long-random-string

# Optional: override the registration-link origin (defaults to Netlify's auto URL)
# PUBLIC_SITE_URL=https://your-site.netlify.app
